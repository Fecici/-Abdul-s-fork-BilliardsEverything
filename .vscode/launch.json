{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach Java to Gradle run (5005)",
      "type": "java",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005,
      "timeout": 60000
    },
    {
      "name": "Attach native GDB to running Java",
      "type": "cppdbg",
      "request": "attach",
      "program": "C:/Program Files/Java/jdk-17/bin/java.exe",
      "processId": "${command:pickProcess}",
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "cwd": "${workspaceFolder}",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Use Intel disassembly syntax",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug native Boost tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/exe/test/test.exe",
      "args": ["--log_level=test_suite"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "C:\\msys64\\ucrt64\\bin;${env:PATH}"
        }
      ],
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "preLaunchTask": "build: native debug + tests",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug reported long MRR workload",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/exe/test/test.exe",
      "args": [
        "--run_test=benchmark_reported_long_cs_mrr",
        "--log_level=test_suite"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        { "name": "PATH", "value": "C:\\msys64\\ucrt64\\bin;${env:PATH}" },
        { "name": "BILLIARDS_RUN_BENCHMARKS", "value": "1" },
        { "name": "BILLIARDS_BENCHMARK_WORKER", "value": "2" },
        { "name": "BILLIARDS_NATIVE_THREADS", "value": "2" }
      ],
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "preLaunchTask": "build: native debug + tests",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
